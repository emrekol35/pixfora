# Database
DATABASE_URL="postgresql://pixfora:pixfora_secret@localhost:5432/pixfora?schema=public"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Redis
REDIS_URL="redis://localhost:6379"

# Email (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@pixfora.com"

# Site
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Pixfora"

# Upload
UPLOAD_DIR="public/uploads"
MAX_FILE_SIZE=5242880

# Web Push (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY="generate-with-npx-web-push-generate-vapid-keys"
VAPID_PRIVATE_KEY="generate-with-npx-web-push-generate-vapid-keys"
VAPID_SUBJECT="mailto:info@pixfora.com"

# Cron Jobs
CRON_SECRET="generate-a-random-secret-here"
