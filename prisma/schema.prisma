generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// KULLANICI & AUTH
// ============================================================

enum UserRole {
  ADMIN
  CUSTOMER
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String?
  name          String
  phone         String?
  role          UserRole  @default(CUSTOMER)
  isBlacklisted Boolean   @default(false) @map("is_blacklisted")
  emailVerified DateTime? @map("email_verified")
  image         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  groupId String?    @map("group_id")
  group   UserGroup? @relation(fields: [groupId], references: [id])

  addresses     Address[]
  orders        Order[]
  reviews       Review[]
  cartItems     CartItem[]
  notifications Notification[]
  wishlists     Wishlist[]
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model UserGroup {
  id              String  @id @default(cuid())
  name            String  @unique
  discountPercent Float   @default(0) @map("discount_percent")
  description     String?

  users          User[]
  groupDiscounts GroupDiscount[]

  @@map("user_groups")
}

model Address {
  id        String  @id @default(cuid())
  userId    String  @map("user_id")
  title     String
  firstName String  @map("first_name")
  lastName  String  @map("last_name")
  phone     String
  city      String
  district  String
  neighborhood String?
  address   String
  zipCode   String? @map("zip_code")
  isDefault Boolean @default(false) @map("is_default")
  type      String  @default("shipping") // shipping | billing

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  shippingOrders Order[] @relation("ShippingAddress")
  billingOrders  Order[] @relation("BillingAddress")

  @@map("addresses")
}

// ============================================================
// URUN & KATALOG
// ============================================================

model Category {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String? @db.Text
  image       String?
  order       Int     @default(0)
  isActive    Boolean @default(true) @map("is_active")

  // SEO
  seoTitle       String? @map("seo_title")
  seoDescription String? @map("seo_description") @db.Text
  seoKeywords    String? @map("seo_keywords")

  // Self-referencing for unlimited nesting
  parentId String?    @map("parent_id")
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")

  products Product[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("categories")
}

model Brand {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  logo        String?
  description String? @db.Text
  isActive    Boolean @default(true) @map("is_active")
  order       Int     @default(0)

  // SEO
  seoTitle       String? @map("seo_title")
  seoDescription String? @map("seo_description") @db.Text
  seoKeywords    String? @map("seo_keywords")

  products Product[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("brands")
}

model Product {
  id           String  @id @default(cuid())
  name         String
  slug         String  @unique
  description  String? @db.Text
  shortDesc    String? @map("short_desc") @db.Text
  sku          String? @unique
  barcode      String?
  price        Float
  comparePrice Float?  @map("compare_price")
  costPrice    Float?  @map("cost_price")
  stock        Int     @default(0)
  minQty       Int     @default(1) @map("min_qty")
  maxQty       Int?    @map("max_qty")
  weight       Float?
  desi         Float?
  isActive     Boolean @default(true) @map("is_active")
  isFeatured   Boolean @default(false) @map("is_featured")
  membersOnly  Boolean @default(false) @map("members_only")
  hasVariants  Boolean @default(false) @map("has_variants")

  // SEO
  seoTitle       String? @map("seo_title")
  seoDescription String? @map("seo_description") @db.Text
  seoKeywords    String? @map("seo_keywords")

  // Relations
  categoryId String?   @map("category_id")
  category   Category? @relation(fields: [categoryId], references: [id])
  brandId    String?   @map("brand_id")
  brand      Brand?    @relation(fields: [brandId], references: [id])

  images              ProductImage[]
  variants            ProductVariant[]
  variantTypes        VariantType[]
  tags                ProductTag[]
  reviews             Review[]
  cartItems           CartItem[]
  orderItems          OrderItem[]
  complementaryFrom   ComplementaryProduct[] @relation("MainProduct")
  complementaryTo     ComplementaryProduct[] @relation("CompProduct")
  giftProducts        GiftProduct[]
  wishlists           Wishlist[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([categoryId])
  @@index([brandId])
  @@index([isActive])
  @@index([price])
  @@map("products")
}

model ProductImage {
  id        String @id @default(cuid())
  productId String @map("product_id")
  url       String
  alt       String?
  order     Int    @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model VariantType {
  id        String @id @default(cuid())
  productId String @map("product_id")
  name      String // e.g., "Renk", "Beden"
  order     Int    @default(0)

  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  options VariantOption[]

  @@map("variant_types")
}

model VariantOption {
  id            String @id @default(cuid())
  variantTypeId String @map("variant_type_id")
  value         String // e.g., "Kirmizi", "M"
  order         Int    @default(0)

  variantType VariantType @relation(fields: [variantTypeId], references: [id], onDelete: Cascade)

  @@map("variant_options")
}

model ProductVariant {
  id         String  @id @default(cuid())
  productId  String  @map("product_id")
  sku        String? @unique
  barcode    String?
  price      Float?
  stock      Int     @default(0)
  isActive   Boolean @default(true) @map("is_active")
  options    Json    // e.g., {"Renk": "Kirmizi", "Beden": "M"}

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@map("product_variants")
}

model ProductTag {
  id        String @id @default(cuid())
  productId String @map("product_id")
  tag       String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([tag])
  @@map("product_tags")
}

model ComplementaryProduct {
  id              String @id @default(cuid())
  mainProductId   String @map("main_product_id")
  compProductId   String @map("comp_product_id")

  mainProduct Product @relation("MainProduct", fields: [mainProductId], references: [id], onDelete: Cascade)
  compProduct Product @relation("CompProduct", fields: [compProductId], references: [id], onDelete: Cascade)

  @@unique([mainProductId, compProductId])
  @@map("complementary_products")
}

model GiftProduct {
  id           String  @id @default(cuid())
  productId    String  @map("product_id")
  giftName     String  @map("gift_name")
  giftImage    String? @map("gift_image")
  minOrderQty  Int     @default(1) @map("min_order_qty")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("gift_products")
}

// ============================================================
// SEPET
// ============================================================

model CartItem {
  id        String  @id @default(cuid())
  userId    String? @map("user_id")
  sessionId String? @map("session_id")
  productId String  @map("product_id")
  variantId String? @map("variant_id")
  quantity  Int     @default(1)

  user    User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("cart_items")
}

// ============================================================
// SIPARIS & ODEME
// ============================================================

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CREDIT_CARD
  BANK_TRANSFER
  CASH_ON_DELIVERY
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique @map("order_number")
  userId          String?       @map("user_id")
  guestEmail      String?       @map("guest_email")
  guestPhone      String?       @map("guest_phone")
  guestName       String?       @map("guest_name")
  status          OrderStatus   @default(PENDING)
  paymentMethod   PaymentMethod @map("payment_method")
  paymentStatus   PaymentStatus @default(PENDING) @map("payment_status")
  subtotal        Float
  shippingCost    Float         @default(0) @map("shipping_cost")
  discount        Float         @default(0)
  total           Float
  note            String?       @db.Text
  trackingNumber  String?       @map("tracking_number")
  shippingCompany String?       @map("shipping_company")

  shippingAddressId String?  @map("shipping_address_id")
  billingAddressId  String?  @map("billing_address_id")
  shippingAddress   Address? @relation("ShippingAddress", fields: [shippingAddressId], references: [id])
  billingAddress    Address? @relation("BillingAddress", fields: [billingAddressId], references: [id])

  couponId String? @map("coupon_id")
  coupon   Coupon? @relation(fields: [couponId], references: [id])

  user     User?       @relation(fields: [userId], references: [id])
  items    OrderItem[]
  payments Payment[]
  invoice  Invoice?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@index([orderNumber])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String  @map("order_id")
  productId String  @map("product_id")
  variantId String? @map("variant_id")
  name      String
  sku       String?
  price     Float
  quantity  Int
  total     Float
  options   Json?

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

model Payment {
  id            String        @id @default(cuid())
  orderId       String        @map("order_id")
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  amount        Float
  transactionId String?       @map("transaction_id")
  provider      String?
  providerData  Json?         @map("provider_data")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@map("payments")
}

model Invoice {
  id          String  @id @default(cuid())
  orderId     String  @unique @map("order_id")
  invoiceNo   String  @unique @map("invoice_no")
  type        String  @default("e-arsiv") // e-arsiv | e-fatura
  companyName String? @map("company_name")
  taxOffice   String? @map("tax_office")
  taxNumber   String? @map("tax_number")
  data        Json?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@map("invoices")
}

// ============================================================
// INDIRIM & KAMPANYA
// ============================================================

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
}

model Coupon {
  id           String       @id @default(cuid())
  code         String       @unique
  type         DiscountType
  value        Float
  minOrder     Float?       @map("min_order")
  maxDiscount  Float?       @map("max_discount")
  maxUses      Int?         @map("max_uses")
  usedCount    Int          @default(0) @map("used_count")
  isActive     Boolean      @default(true) @map("is_active")
  startsAt     DateTime?    @map("starts_at")
  expiresAt    DateTime?    @map("expires_at")

  orders Order[]

  createdAt DateTime @default(now()) @map("created_at")

  @@map("coupons")
}

model Campaign {
  id          String       @id @default(cuid())
  name        String
  type        DiscountType
  value       Float
  conditions  Json?
  isActive    Boolean      @default(true) @map("is_active")
  startsAt    DateTime?    @map("starts_at")
  expiresAt   DateTime?    @map("expires_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("campaigns")
}

model GroupDiscount {
  id          String  @id @default(cuid())
  groupId     String  @map("group_id")
  targetType  String  @map("target_type") // category | brand | product
  targetId    String  @map("target_id")
  discount    Float

  group UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@map("group_discounts")
}

// ============================================================
// ICERIK YONETIMI (CMS)
// ============================================================

model Page {
  id          String  @id @default(cuid())
  title       String
  slug        String  @unique
  content     String  @db.Text
  isActive    Boolean @default(true) @map("is_active")
  order       Int     @default(0)

  seoTitle       String? @map("seo_title")
  seoDescription String? @map("seo_description") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("pages")
}

model BlogCategory {
  id    String @id @default(cuid())
  name  String
  slug  String @unique
  order Int    @default(0)

  posts BlogPost[]

  @@map("blog_categories")
}

model BlogPost {
  id         String  @id @default(cuid())
  title      String
  slug       String  @unique
  content    String  @db.Text
  excerpt    String? @db.Text
  image      String?
  isActive   Boolean @default(true) @map("is_active")
  categoryId String? @map("category_id")

  seoTitle       String? @map("seo_title")
  seoDescription String? @map("seo_description") @db.Text

  category BlogCategory? @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("blog_posts")
}

model Slide {
  id       String  @id @default(cuid())
  title    String?
  subtitle String?
  image    String
  link     String?
  order    Int     @default(0)
  isActive Boolean @default(true) @map("is_active")

  @@map("slides")
}

model Menu {
  id       String @id @default(cuid())
  name     String @unique
  items    Json
  location String @default("header") // header | footer | mobile

  @@map("menus")
}

model Popup {
  id        String  @id @default(cuid())
  title     String
  content   String  @db.Text
  image     String?
  type      String  @default("general") // general | exit | promotion
  isActive  Boolean @default(true) @map("is_active")
  showOnce  Boolean @default(true) @map("show_once")
  delay     Int     @default(0)

  @@map("popups")
}

model Announcement {
  id       String  @id @default(cuid())
  text     String
  link     String?
  bgColor  String  @default("#000000") @map("bg_color")
  textColor String @default("#ffffff") @map("text_color")
  isActive Boolean @default(true) @map("is_active")
  type     String  @default("bar") // bar | notification

  @@map("announcements")
}

// ============================================================
// DEGERLENDIRME & ILETISIM
// ============================================================

model Review {
  id         String  @id @default(cuid())
  productId  String  @map("product_id")
  userId     String  @map("user_id")
  rating     Int
  comment    String? @db.Text
  isApproved Boolean @default(false) @map("is_approved")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@map("reviews")
}

model ContactMessage {
  id      String  @id @default(cuid())
  name    String
  email   String
  phone   String?
  subject String
  message String  @db.Text
  isRead  Boolean @default(false) @map("is_read")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("contact_messages")
}

// ============================================================
// SEO & YONLENDIRME
// ============================================================

model Redirect {
  id       String @id @default(cuid())
  fromPath String @unique @map("from_path")
  toPath   String @map("to_path")
  type     Int    @default(301)

  createdAt DateTime @default(now()) @map("created_at")

  @@map("redirects")
}

// ============================================================
// BILDIRIM & E-BULTEN
// ============================================================

model EmailTemplate {
  id        String @id @default(cuid())
  name      String @unique
  subject   String
  body      String @db.Text
  variables Json?

  @@map("email_templates")
}

model Newsletter {
  id    String @id @default(cuid())
  email String @unique

  createdAt DateTime @default(now()) @map("created_at")

  @@map("newsletters")
}

model Notification {
  id      String  @id @default(cuid())
  userId  String  @map("user_id")
  type    String
  title   String
  message String
  isRead  Boolean @default(false) @map("is_read")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@map("notifications")
}

// ============================================================
// SISTEM
// ============================================================

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text
  group String @default("general")

  @@map("settings")
}

model Integration {
  id       String  @id @default(cuid())
  service  String  @unique
  isActive Boolean @default(false) @map("is_active")
  config   Json?

  @@map("integrations")
}

model ActivityLog {
  id        String @id @default(cuid())
  userId    String? @map("user_id")
  action    String
  entity    String
  entityId  String? @map("entity_id")
  details   Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([entity, entityId])
  @@map("activity_logs")
}

model Media {
  id       String @id @default(cuid())
  url      String
  filename String
  mimeType String @map("mime_type")
  size     Int
  alt      String?
  folder   String @default("general")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("media")
}

model Wishlist {
  id        String @id @default(cuid())
  userId    String @map("user_id")
  productId String @map("product_id")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, productId])
  @@map("wishlists")
}
